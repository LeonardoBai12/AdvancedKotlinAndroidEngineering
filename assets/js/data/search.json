---
layout: compress
swcache: true
---

[
  {% assign doc_pages = site.pages | where: "layout", "page" | sort: "url" %}
  {% for p in doc_pages %}
  {
    "title": {{ p.title | jsonify }},
    "url": {{ p.url | relative_url | jsonify }},
    "categories": "",
    "tags": "",
    "date": "",
    "content": {{ p.content | strip_html | normalize_whitespace | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
